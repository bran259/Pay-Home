<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose your preferred payment method:"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/payment_methods_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rb_mpesa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="M-Pesa"
            android:textSize="16sp"
            android:padding="12dp"
            android:buttonTint="@color/primary_blue"
            android:checked="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Fast and secure mobile money"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="8dp" />

        <RadioButton
            android:id="@+id/rb_bank_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bank Card"
            android:textSize="16sp"
            android:padding="12dp"
            android:buttonTint="@color/primary_blue"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Visa, Mastercard, and other cards"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="8dp" />

        <RadioButton
            android:id="@+id/rb_mobile_banking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mobile Banking"
            android:textSize="16sp"
            android:padding="12dp"
            android:buttonTint="@color/primary_blue"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Direct bank transfer"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="16dp" />

    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btn_cancel_payment_method"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancel"
            android:textColor="@color/text_secondary"
            android:background="@android:color/transparent"
            android:padding="12dp" />

        <Button
            android:id="@+id/btn_confirm_payment_method"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Confirm"
            android:textColor="@color/white"
            android:background="@color/primary_blue"
            android:padding="12dp" />

    </LinearLayout>

</LinearLayout>
